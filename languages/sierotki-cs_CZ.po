#: etc/options.php:51
msgid "Terms"
msgstr "Podmínky"

#: etc/options.php:57
msgid "Language File"
msgstr "Jazykový soubor"

#: etc/options.php:61
msgid "Try to use the site locale to determine the file name"
msgstr "Zkuste k určení názvu souboru použít národní prostředí webu"

#: etc/options.php:62
msgid ""
"Select if you want the plugin to determine which file to load based on the "
"site's language settings."
msgstr ""
"Vyberte, zda chcete, aby plugin určil, který soubor načíst, na základě "
"jazykového nastavení webu."

#: etc/options.php:65
msgid "Polish"
msgstr "Polština"

#: etc/options.php:66
msgid "Select if you want to force the loading of Polish language rules."
msgstr "Vyberte, pokud chcete vynutit načítání pravidel polského jazyka."

